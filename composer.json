{
  "name": "school/api-backend",
  "description": "API REST en PHP puro para App Inventor y Google Sheets",
  "type": "project",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "files": [
      "app/helpers/JsonHelper.php",
      "app/helpers/ResponseHelper.php",
      "app/helpers/XmlHelper.php",
      "app/config/app.php",
      "app/config/cors.php",
      "app/config/googleSheets.php"
    ]
  },
  "config": {
    "optimize-autoloader": true
  }
}
